# ═══════════════════════════════════════════════════════
# HushAsk — Environment Variables
# Copy to .env and fill in all required values.
# Never commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── Slack ───────────────────────────────────────────────
# From api.slack.com/apps → your app → credentials
SLACK_BOT_TOKEN=xoxb-...
SLACK_SIGNING_SECRET=...
SLACK_APP_TOKEN=xapp-...          # Socket Mode app-level token

# ── Notion OAuth ────────────────────────────────────────
# Create a PUBLIC integration at notion.so/my-integrations
# Set redirect URI to: https://api.hushask.com/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=https://api.hushask.com/notion/callback

# ── Stripe (billing) ────────────────────────────────────
# From dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRO_PRICE_ID=price_...     # Monthly Pro plan price ID

# ── App config ──────────────────────────────────────────
HASH_SALT=hushask-v1-salt         # Change this to a long random string in production
DB_PATH=hushask.db
FREE_LIMIT=20                     # Free tier monthly message cap

# ── URLs ────────────────────────────────────────────────
UPGRADE_URL=https://hushask.com/upgrade
HELP_BASE=https://hushask.com/help

# ── Infrastructure ──────────────────────────────────────
# Railway injects PORT automatically — do not set manually on Railway
PORT=8080
