# ═══════════════════════════════════════════════════════
# HushAsk — Environment Variables
# Copy to .env and fill in all required values.
# NEVER commit .env to version control.
# ═══════════════════════════════════════════════════════

# ── Slack ───────────────────────────────────────────────
# From api.slack.com/apps → your app → Basic Information
SLACK_CLIENT_ID=
SLACK_CLIENT_SECRET=
SLACK_SIGNING_SECRET=
SLACK_APP_ID=                     # App ID shown on Basic Information page

# ── Notion OAuth ────────────────────────────────────────
# PUBLIC integration at notion.so/my-integrations
# Redirect URI must be: https://api.hushask.com/notion/callback
NOTION_CLIENT_ID=
NOTION_CLIENT_SECRET=
NOTION_REDIRECT_URI=https://api.hushask.com/notion/callback

# ── Stripe ──────────────────────────────────────────────
# From dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_live_...
STRIPE_PUBLISHABLE_KEY=pk_live_...
STRIPE_WEBHOOK_SECRET=whsec_...   # From Stripe Dashboard → Webhooks → signing secret
STRIPE_PRO_PRICE_ID=price_...     # Monthly Pro subscription price ID

# ── App config ──────────────────────────────────────────
HASH_SALT=                        # REQUIRED: long random string, e.g. openssl rand -hex 32
DB_PATH=hushask.db
FREE_LIMIT=20                     # Free tier monthly cap

# ── URLs ────────────────────────────────────────────────
API_BASE=https://api.hushask.com
SITE_BASE=https://hushask.com
UPGRADE_URL=https://hushask.com/upgrade
HELP_BASE=https://hushask.com/help

# ── Infrastructure ──────────────────────────────────────
# PORT is injected automatically by Railway — do not set manually
# WEB_WORKERS=2
